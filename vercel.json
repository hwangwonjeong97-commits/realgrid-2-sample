{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/wehago-realgrid",
      "destination": "/wehago-realgrid.html"
    },
    {
      "source": "/wehago-realgrid/:path*",
      "destination": "/wehago-realgrid.html"
    }
  ]
}
